<?php
$currentPage = $view->currentPage ?? 1;
$totalPages = $view->totalPages ?? 1;
$baseUrl = "index.php?page=sightings";
$queryParams = $_GET;
unset($queryParams['pageNum']);
$queryString = http_build_query($queryParams);

$buildUrl = function ($pageNum) use ($baseUrl, $queryString) {
    return $baseUrl . ($queryString ? '&' . $queryString : '') . '&pageNum=' . (int)$pageNum;
};
?>

<div class="d-flex justify-content-center mt-4 align-items-center gap-3 flex-wrap">

<?php if ($currentPage > 1): ?>
<a href="<?= $buildUrl($currentPage - 1) ?>" class="btn btn-outline-primary">Previous</a>
<?php endif; ?>

<div class="pagination-links">

<?php
$start = max(1, $currentPage - 2);
$end = min($totalPages, $currentPage + 2);
?>

<?php if ($start > 1): ?>
<a class="page-link" href="<?= $buildUrl(1) ?>">1</a>
<?php if ($start > 2): ?><span class="page-ellipsis">…</span><?php endif; ?>
<?php endif; ?>

<?php for ($i = $start; $i <= $end; $i++): ?>
<a class="page-link <?= ($i === $currentPage) ? 'active' : '' ?>" href="<?= $buildUrl($i) ?>"><?= $i ?></a>
<?php endfor; ?>

<?php if ($end < $totalPages): ?>
<?php if ($end < $totalPages - 1): ?><span class="page-ellipsis">…</span><?php endif; ?>
<a class="page-link" href="<?= $buildUrl($totalPages) ?>"><?= $totalPages ?></a>
<?php endif; ?>

</div>

<?php if ($currentPage < $totalPages): ?>
<a href="<?= $buildUrl($currentPage + 1) ?>" class="btn btn-outline-primary">Next</a>
<?php endif; ?>

<form method="GET" class="jump-form d-flex align-items-center gap-2">
<?php foreach ($queryParams as $k => $v): ?>
<input type="hidden" name="<?= htmlspecialchars($k) ?>" value="<?= htmlspecialchars($v) ?>">
<?php endforeach; ?>

<label class="small text-muted">Page</label>
<input type="number" min="1" max="<?= (int)$totalPages ?>" name="pageNum" class="form-control form-control-sm" style="width:80px;" value="<?= (int)$currentPage ?>">
<span class="small text-muted">of <?= (int)$totalPages ?></span>
<button type="submit" class="btn btn-sm btn-outline-secondary">Go</button>
</form>

</div>

